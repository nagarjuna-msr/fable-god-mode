{
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "findings", "summary"],
  "properties": {
    "verdict": { "type": "string", "enum": ["approved", "findings"] },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "category", "where", "issue", "suggestion"],
        "properties": {
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "category": { "type": "string" },
          "where": { "type": "string" },
          "issue": { "type": "string" },
          "suggestion": { "type": "string" }
        }
      }
    }
  }
}
